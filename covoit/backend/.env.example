# ============================================================================
# COVOIT — Variables d'environnement (copier vers .env)
# ============================================================================

# PostgreSQL
POSTGRES_USER=covoit
POSTGRES_PASSWORD=covoit_secret

# RabbitMQ
RABBITMQ_USER=covoit
RABBITMQ_PASS=covoit_secret

# JWT
SECRET_KEY=change-me-in-production-use-a-random-string

# OpenAI
OPENAI_API_KEY=
