# Monetbil (payment service)
MONETBIL_API_BASE_URL=https://api.monetbil.com/payment/v1
MONETBIL_SERVICE_KEY=
MONETBIL_NOTIFY_URL=
MONETBIL_RETURN_URL=
MONETBIL_COUNTRY=CM
