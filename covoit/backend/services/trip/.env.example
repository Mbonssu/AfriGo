# Configuration du Trip Service
# Copier ce fichier vers .env et remplir avec vos valeurs

# Mode debug (True = affiche les requêtes SQL et stack traces)
DEBUG=False

# URL complète de la base de données
# Format: postgresql://username:password@host:port/database
# utilisateur: postgres
# mot de passe: postgres (à changer en prod)
# host: postgres-trip (nom du conteneur Docker, ou localhost pour dev local)
# port: 5434 (séparé des autres services)
# dbname: trip_db
DATABASE_URL=postgresql://postgres:postgres@postgres-trip:5434/trip_db

# Clé secrète pour la signature JWT et opérations cryptographiques
# À CHANGER en production avec une longue chaîne aléatoire
# Exemple secure: openssl rand -hex 32
SECRET_KEY=your-secret-key-trip-service-change-in-production
