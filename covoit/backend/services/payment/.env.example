# PAYMENT SERVICE - CONFIGURATION D'ENVIRONNEMENT
# ============================================================================
# Copier ce fichier et renommer en .env, puis remplir les valeurs réelles
# Exemple: cp .env.example .env

# ============================================================================
# CONFIGURATION DE LA BASE DE DONNÉES
# ============================================================================

# URL de connexion à PostgreSQL
# Format: postgresql://utilisateur:motdepasse@host:port/base_de_donnees
# En développement: utiliser localhost
# En Docker: utiliser le nom du service (postgres-payment)
DATABASE_URL=postgresql://postgres:postgres@postgres-payment:5435/payment_db

# ============================================================================
# CONFIGURATION DE L'APPLICATION
# ============================================================================

# Mode DEBUG (True en développement, False en production)
# En mode DEBUG, les erreurs détaillées sont affichées et l'app auto-recharge
DEBUG=True

# Clé secrète pour signer les tokens JWT et les cookies
# IMPORTANT: Générer une clé aléatoire sécurisée en production
# Exemple de génération: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-me-in-production

# ============================================================================
# CONFIGURATION DES PRESTATAIRES DE PAIEMENT
# ============================================================================

# Clé API pour MTN Mobile Money
MTN_API_KEY=your-mtn-api-key

# Clé API pour Orange Money
ORANGE_API_KEY=your-orange-api-key

# ============================================================================
# CONFIGURATION FASTAPI
# ============================================================================

# Hôte d'écoute
APP_HOST=0.0.0.0

# Port d'écoute
APP_PORT=8006

# Titre de l'API Swagger
APP_TITLE=Payment Service API

# Version de l'API
APP_VERSION=1.0.0

# ============================================================================
# CONFIGURATION DE LOGGING
# ============================================================================

# Niveau de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Emplacement du fichier de log
LOG_FILE=/var/log/payment-service.log

# ============================================================================
# CONFIGURATION DES SERVICES EXTERNES
# ============================================================================

# URL du service API Gateway (pour les appels inter-services)
API_GATEWAY_URL=http://localhost:8000

# URL du service Trip (pour vérifier les réservations)
TRIP_SERVICE_URL=http://localhost:8003

# URL du service Booking (pour vérifier les réservations)
BOOKING_SERVICE_URL=http://localhost:8004
