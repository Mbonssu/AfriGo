# BOOKING SERVICE - CONFIGURATION D'ENVIRONNEMENT
# ============================================================================
# Copier ce fichier et renommer en .env, puis remplir les valeurs réelles

# URL de connexion à PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres-booking:5432/booking_db

# Mode DEBUG
DEBUG=True

# Clé secrète pour signer les tokens JWT
SECRET_KEY=your-secret-key-change-me-in-production

# Configuration FastAPI
APP_HOST=0.0.0.0
APP_PORT=8004
APP_TITLE=Booking Service API
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/booking-service.log

# Configuration des services externes
API_GATEWAY_URL=http://localhost:8000
TRIP_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8006
